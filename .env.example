# ──────────────────────────────────────────────────────────────────
# Volt environment variables
# Copy to .env.local for local dev, or set in Azure App Service >
# Configuration > Application settings for production.
# ──────────────────────────────────────────────────────────────────

# ── Database (Azure SQL) ─────────────────────────────────────────
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=volt
SQL_USER=your-sql-admin
SQL_PASSWORD=your-sql-password
SQL_PORT=1433

# ── Microsoft SSO ────────────────────────────────────────────────
# Azure AD App Registration (covers work/school + personal Microsoft accounts)
# Redirect URI to register: https://your-app.azurewebsites.net/api/auth/sso-callback
AZURE_TENANT_ID=common
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Also expose the client ID to the browser for building the login redirect URL:
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_TENANT_ID=common

# ── Google SSO ───────────────────────────────────────────────────
# Google Cloud OAuth Client (Gmail + Google Workspace)
# Redirect URI to register: https://your-app.azurewebsites.net/api/auth/sso-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── App URL (required for OAuth redirect URIs) ───────────────────
NEXT_PUBLIC_APP_URL=https://your-app.azurewebsites.net

# ── Outbound email (notifications, ticket reminders, EmailV) ─────
# Works with Microsoft 365, Google Workspace, or any SMTP relay
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@yourcompany.com
SMTP_PASSWORD=
VOLT_EMAIL_FROM="Volt <notifications@yourcompany.com>"

# ── Volty AI Assistant ───────────────────────────────────────────
# Free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
