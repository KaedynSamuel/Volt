# ── Volt Desktop — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values before building.
# NEVER commit .env.local to version control.

# ── Database (required) ───────────────────────────────────────────────────────
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=VoltDB
SQL_USER=voltadmin
SQL_PASSWORD=your-secure-password-here

# ── Email (optional — for EmailV and notifications) ──────────────────────────
# Point this to your email delivery webhook/API
VOLT_EMAIL_WEBHOOK_URL=https://your-service.com/api/send-email
VOLT_EMAIL_WEBHOOK_SECRET=your-webhook-secret
VOLT_EMAIL_FROM=Volt <no-reply@yourdomain.com>

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXTAUTH_SECRET=generate-a-long-random-string-here
